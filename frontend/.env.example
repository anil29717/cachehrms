# Optional: API base URL (defaults to /api/v1 for same-origin)
# VITE_API_BASE_URL=/api/v1

# Optional: Use this when sharing the onboarding link with someone on the same WiFi.
# Set to your computer's IP and port so the link works on their device.
# Example: when you run `npm run dev`, the terminal shows "Network: http://192.168.1.5:3000" — use that.
# VITE_PUBLIC_ORIGIN=http://192.168.1.5:3000
