# Copy to .env in this folder. Do not commit .env.

# Database: use a reachable host. If PostgreSQL runs on this machine, use localhost.
# If the server at 172.16.x.x is unreachable (e.g. you're off VPN), switch to your local DB.
DATABASE_URL="postgresql://hrms_user:StrongPassword1@172.16.110.46:5432/cachedigitech_hrms"
JWT_SECRET="your-super-secret-key-min-32-chars"
JWT_EXPIRY="8h"
REFRESH_TOKEN_SECRET="your-refresh-secret-key"
REFRESH_TOKEN_EXPIRY="7d"
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Frontend URL (for SSO redirect after Microsoft login)
FRONTEND_URL=http://localhost:3000

# Microsoft SSO (optional). Register app at https://entra.microsoft.com → App registrations.
# Add redirect URI: https://your-api-host/api/v1/auth/microsoft/callback (or http://localhost:4000/api/v1/auth/microsoft/callback for dev)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# For single-tenant apps (default since Oct 2018), set your Azure AD Tenant ID (Entra → Overview → Tenant ID). Leave empty only if app is multi-tenant.
# MICROSOFT_TENANT_ID=
